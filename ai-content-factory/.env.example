# Future: S3/R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
CLOUDFLARE_R2_ENDPOINT=

# App Config
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
MAX_VIDEO_SIZE_GB=10
MAX_VIDEO_DURATION_HOURS=3

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# VIDEO QUALITY (Fix 1)
# ============================================================
# yt-dlp format priority: 2K → 1080p → best available
YTDLP_FORMAT_PRIORITY=2k_first

# FFmpeg encoder: auto = detect NVENC (RTX 4070) or fall back to libx264
FFMPEG_ENCODER=auto
# Adaptive CQ/CRF values per source resolution
FFMPEG_CQ_2K=18
FFMPEG_CQ_1080P=21
FFMPEG_CQ_DEFAULT=23
FFMPEG_CRF_2K=18
FFMPEG_CRF_1080P=20
FFMPEG_CRF_DEFAULT=22
# Thumbnail sharpness (requires opencv-python-headless, needs docker rebuild)
THUMBNAIL_JPEG_QUALITY=1

# ============================================================
# CLIP DURATION RULES (Fix 2) — format: min,ideal_min,ideal_max,max (seconds)
# ============================================================
CLIP_DURATION_CLUTCH=45,55,75,90
CLIP_DURATION_FUNNY=20,25,45,60
CLIP_DURATION_ACHIEVEMENT=60,70,90,120
CLIP_DURATION_RAGE=30,40,60,75
CLIP_DURATION_EPIC=45,60,90,100
CLIP_DURATION_FAIL=20,30,50,60
CLIP_DURATION_TUTORIAL=45,60,90,120
CLIP_BUILDUP_DEFAULT=8
CLIP_RESOLUTION_DEFAULT=8

# ============================================================
# VERTICAL CROP / FACECAM (Fix 4)
# ============================================================
# OBS Canvas specs — Seego GG: 2560x1440 @60fps
OBS_CANVAS_WIDTH=2560
OBS_CANVAS_HEIGHT=1440
OBS_FPS=60

# Default crop mode for unknown games:
#   blur_pillarbox  = safe, centered with blurred sides (default)
#   smart_offset    = crop from left/right edge (facecam in corner)
#   dual_zone       = split screen: facecam top + gameplay bottom
DEFAULT_VERTICAL_CROP_MODE=blur_pillarbox
DEFAULT_FACECAM_POSITION=top_left
DEFAULT_CROP_X_OFFSET=0
DEFAULT_CROP_ANCHOR=left
DEFAULT_DUAL_ZONE_SPLIT_RATIO=0.38

# Facecam auto-detect (requires opencv-python-headless — needs docker rebuild)
FACECAM_AUTO_DETECT=false
